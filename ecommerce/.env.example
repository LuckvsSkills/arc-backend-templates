# ============================================
# ARC E-COMMERCE BACKEND — OMGEVINGSVARIABELEN
# Forge vult dit automatisch in bij deployment
# ============================================

# Winkel
WINKEL_NAAM=Mijn Webshop
WINKEL_PREFIX=SHOP
WINKEL_EMAIL=info@mijnwebshop.nl
WINKEL_URL=https://mijnwebshop.nl

# Database
DATABASE_URL=postgresql://gebruiker:wachtwoord@localhost:5432/webshop_db

# Security
JWT_SECRET=verander-dit-naar-een-veilige-sleutel

# CORS
TOEGESTANE_ORIGINS=["https://mijnwebshop.nl","https://www.mijnwebshop.nl"]

# Betaling (kies provider)
BETAAL_PROVIDER=mollie
MOLLIE_API_KEY=test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_GEBRUIKER=info@mijnwebshop.nl
SMTP_WACHTWOORD=app-wachtwoord

# Storage
STORAGE_TYPE=s3
S3_BUCKET=mijnwebshop-media
S3_REGIO=eu-west-1
S3_TOEGANG_KEY=AKIAXXXXXXXXXXXXXXXX
S3_GEHEIM_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Agent (optioneel)
AGENT_ACTIEF=false
AGENT_API_URL=https://agent.mijnwebshop.nl
AGENT_TOKEN=
